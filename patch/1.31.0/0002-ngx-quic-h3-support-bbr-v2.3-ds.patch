+    ngx_uint_t                       recovery_state;
+
+    ngx_quic_bbr_max_filter_t        max_bw_filter;
+    uint64_t                         max_bw;
+    uint64_t                         full_bw;
+    uint64_t                         pacing_rate;
+
+    size_t                           cwnd;
+    size_t                           recovery_window;
+    size_t                           initial_cwnd;
+    size_t                           min_cwnd;
+    size_t                           max_cwnd;
+    size_t                           max_datagram;
+    size_t                           cwnd_to_calculate_min_pacing_rate;
+
+    ngx_msec_t                       min_rtt;
+    ngx_msec_t                       min_rtt_stamp;
+    ngx_msec_t                       cycle_stamp;
+    ngx_msec_t                       probe_rtt_done_stamp;
+
+    uint64_t                         round_count;
+    uint64_t                         last_sent_packet;
+    uint64_t                         current_round_end;
+    uint64_t                         end_recovery_at;
+    uint64_t                         bytes_lost_in_round;
+    uint64_t                         bytes_lost_while_detecting_overshooting;
+
+    ngx_uint_t                       num_loss_events_in_round;
+    ngx_uint_t                       rounds_without_bw_gain;
+    ngx_uint_t                       cycle_index;
+
+    ngx_uint_t                       high_gain;
+    ngx_uint_t                       high_cwnd_gain;
+    ngx_uint_t                       cwnd_gain;
+    ngx_uint_t                       drain_gain;
+    ngx_uint_t                       pacing_gain;
+    ngx_uint_t                       congestion_window_gain;
+    ngx_uint_t                       num_startup_rtts;
+    ngx_uint_t                       bytes_lost_multiplier;
+
+    ngx_uint_t                       is_at_full_bandwidth;
+    ngx_uint_t                       last_sample_is_app_limited;
+    ngx_uint_t                       has_non_app_limited_sample;
+    ngx_uint_t                       exiting_quiescence;
+    ngx_uint_t                       probe_rtt_round_passed;
+
+    ngx_uint_t                       drain_to_target;
+    ngx_uint_t                       detect_overshooting;
+    ngx_uint_t                       enable_ack_aggregation_startup;
+    ngx_uint_t                       expire_ack_aggregation_startup;
+} ngx_quic_bbr_t;
