@@ -90,6 +109,59 @@ ngx_quic_packet_threshold(ngx_quic_send_ctx_t *ctx)
 }
 
 
+static void
+ngx_quic_cc_event_init(ngx_connection_t *c, ngx_quic_cc_event_t *event)
+{
+    ngx_quic_congestion_t  *cg;
+    ngx_quic_connection_t  *qc;
+
+    if (ngx_quic_cc_is_default(c)) {
+        ngx_memzero(event, sizeof(ngx_quic_cc_event_t));
+        return;
+    }
+
+    qc = ngx_quic_get_connection(c);
+    cg = &qc->congestion;
+
+    ngx_memzero(event, sizeof(ngx_quic_cc_event_t));
+
+    event->active = 1;
+    event->now = ngx_current_msec;
+    event->blocked = !ngx_quic_cc_can_send(c, cg->in_flight);
+    event->prior_in_flight = cg->in_flight;
+
+    ngx_quic_sampler_sample_init(&event->sample);
+}
+
+
+static void
+ngx_quic_cc_event_finalize(ngx_connection_t *c, ngx_quic_cc_event_t *event)
+{
+    ngx_quic_congestion_t  *cg;
+    ngx_quic_connection_t  *qc;
+
+    if (!event->active) {
+        return;
+    }
+
+    qc = ngx_quic_get_connection(c);
+    cg = &qc->congestion;
+
+    ngx_quic_cc_on_congestion_event(c, &event->sample,
+                                    event->prior_in_flight, event->now);
+
+    ngx_log_debug5(NGX_LOG_DEBUG_EVENT, c->log, 0,
+                   "quic congestion event cc t:%M win:%uz if:%uz"
+                   " acked:%uz lost:%uz",
+                   event->now, ngx_quic_cc_get_cwnd(c), cg->in_flight,
+                   event->sample.acked_bytes, event->sample.lost_bytes);
+
+    if (event->blocked && ngx_quic_cc_can_send(c, cg->in_flight)) {
+        ngx_post_event(&qc->push, &ngx_posted_events);
+    }
+}
+
+
 ngx_int_t
 ngx_quic_handle_ack_frame(ngx_connection_t *c, ngx_quic_header_t *pkt,
     ngx_quic_frame_t *f)
