@@ -0,0 +1,513 @@
+/*
+ * Copyright (C) Nginx, Inc.
+ */
+
+
+#include <ngx_config.h>
+#include <ngx_core.h>
+#include <ngx_event.h>
+#include <ngx_event_quic_connection.h>
+
+
+static ngx_int_t ngx_quic_cc_default_init(ngx_connection_t *c);
+static void ngx_quic_cc_default_reset_path(ngx_connection_t *c);
+static ngx_uint_t ngx_quic_cc_default_can_send(ngx_connection_t *c,
+    size_t bytes_in_flight);
+static ngx_uint_t ngx_quic_cc_default_has_pacing_budget(ngx_connection_t *c,
+    ngx_msec_t now);
+static size_t ngx_quic_cc_default_pacing_budget(ngx_connection_t *c,
+    ngx_msec_t now);
+static ngx_msec_t ngx_quic_cc_default_time_until_send(ngx_connection_t *c,
+    ngx_msec_t now);
+static void ngx_quic_cc_default_on_packet_sent(ngx_connection_t *c,
+    ngx_quic_frame_t *f);
+static void ngx_quic_cc_default_on_ack_event(ngx_connection_t *c,
+    ngx_quic_sample_t *sample, ngx_msec_t now);
+static void ngx_quic_cc_default_on_loss_event(ngx_connection_t *c,
+    ngx_quic_sample_t *sample, ngx_msec_t now);
+static void ngx_quic_cc_default_on_congestion_event(ngx_connection_t *c,
+    ngx_quic_sample_t *sample, ngx_msec_t now);
+static size_t ngx_quic_cc_default_get_cwnd(ngx_connection_t *c);
+static void ngx_quic_cc_default_set_max_datagram_size(ngx_connection_t *c,
+    size_t max_datagram);
+static void ngx_quic_cc_default_on_persistent_congestion(ngx_connection_t *c);
+static size_t ngx_quic_pacer_max_burst(ngx_quic_pacer_t *p, uint64_t rate);
+
+
+const ngx_quic_cc_ops_t  ngx_quic_cc_default_ops = {
+    ngx_quic_cc_default_init,
+    ngx_quic_cc_default_reset_path,
+    ngx_quic_cc_default_can_send,
+    ngx_quic_cc_default_has_pacing_budget,
+    ngx_quic_cc_default_pacing_budget,
+    ngx_quic_cc_default_time_until_send,
+    ngx_quic_cc_default_on_packet_sent,
+    ngx_quic_cc_default_on_ack_event,
+    ngx_quic_cc_default_on_loss_event,
+    ngx_quic_cc_default_on_congestion_event,
+    ngx_quic_cc_default_get_cwnd,
+    ngx_quic_cc_default_set_max_datagram_size,
+    ngx_quic_cc_default_on_persistent_congestion
+};
+
+
+ngx_int_t
+ngx_quic_cc_init(ngx_connection_t *c)
+{
+    ngx_quic_connection_t  *qc;
+
+    qc = ngx_quic_get_connection(c);
+    if (qc == NULL) {
+        return NGX_ERROR;
+    }
+
+    ngx_quic_pacer_init(&qc->cc.pacer, NGX_QUIC_MIN_INITIAL_SIZE);
+
+    switch (qc->conf->congestion) {
+    case NGX_QUIC_CONGESTION_BBR:
+        qc->cc.ops = &ngx_quic_bbr_ops;
+        break;
+
+    case NGX_QUIC_CONGESTION_BRUTAL:
+        qc->cc.ops = &ngx_quic_brutal_ops;
+        break;
+
+    default:
+        qc->cc.ops = &ngx_quic_cc_default_ops;
+        break;
+    }
+
+    if (!ngx_quic_cc_is_default(c)) {
+        ngx_quic_sampler_init(c);
+    }
+
+    ngx_log_debug3(NGX_LOG_DEBUG_EVENT, c->log, 0,
+                   "quic congestion selected alg:%ui bbr:%ui brutal:%uz",
+                   qc->conf->congestion, qc->conf->bbr_profile,
+                   qc->conf->brutal_up);
+
+    return qc->cc.ops->init(c);
+}
+
+
+void
+ngx_quic_cc_reset_path(ngx_connection_t *c)
+{
+    ngx_quic_connection_t  *qc;
+
+    qc = ngx_quic_get_connection(c);
+    if (qc == NULL) {
+        return;
+    }
+
+    if (!ngx_quic_cc_is_default(c)) {
+        ngx_quic_sampler_reset_path(c);
+    }
+
+    ngx_quic_pacer_init(&qc->cc.pacer, NGX_QUIC_MIN_INITIAL_SIZE);
+
+    if (qc->cc.ops && qc->cc.ops->reset_path) {
+        qc->cc.ops->reset_path(c);
+    }
+
+    ngx_log_debug1(NGX_LOG_DEBUG_EVENT, c->log, 0,
+                   "quic congestion reset path alg:%ui",
+                   qc->conf->congestion);
+}
+
+
+ngx_uint_t
+ngx_quic_cc_is_default(ngx_connection_t *c)
+{
+    ngx_quic_connection_t  *qc;
+
+    qc = ngx_quic_get_connection(c);
+
+    return qc->cc.ops == NULL || qc->cc.ops == &ngx_quic_cc_default_ops;
+}
+
+
+ngx_uint_t
+ngx_quic_cc_can_send(ngx_connection_t *c, size_t bytes_in_flight)
+{
+    ngx_quic_connection_t  *qc;
+
+    qc = ngx_quic_get_connection(c);
+
+    return qc->cc.ops->can_send(c, bytes_in_flight);
+}
+
+
+ngx_uint_t
+ngx_quic_cc_has_pacing_budget(ngx_connection_t *c, ngx_msec_t now)
+{
+    ngx_quic_connection_t  *qc;
+
+    qc = ngx_quic_get_connection(c);
+
+    return qc->cc.ops->has_pacing_budget(c, now);
+}
+
+
+size_t
+ngx_quic_cc_pacing_budget(ngx_connection_t *c, ngx_msec_t now)
+{
+    ngx_quic_connection_t  *qc;
+
+    qc = ngx_quic_get_connection(c);
+
+    return qc->cc.ops->pacing_budget(c, now);
+}
+
+
+ngx_msec_t
+ngx_quic_cc_time_until_send(ngx_connection_t *c, ngx_msec_t now)
+{
+    ngx_quic_connection_t  *qc;
+
+    qc = ngx_quic_get_connection(c);
+
+    return qc->cc.ops->time_until_send(c, now);
+}
+
+
+size_t
+ngx_quic_cc_get_cwnd(ngx_connection_t *c)
+{
+    ngx_quic_connection_t  *qc;
+
+    qc = ngx_quic_get_connection(c);
+
+    return qc->cc.ops->get_cwnd(c);
+}
+
+
+void
+ngx_quic_cc_on_packet_sent(ngx_connection_t *c, ngx_quic_frame_t *f)
+{
+    ngx_quic_connection_t  *qc;
+
+    if (f->plen == 0) {
+        return;
+    }
+
+    qc = ngx_quic_get_connection(c);
+
+    if (qc->cc.pacer.max_datagram != qc->path->mtu) {
+        ngx_quic_pacer_set_max_datagram(&qc->cc.pacer, qc->path->mtu);
+        qc->cc.ops->set_max_datagram_size(c, qc->path->mtu);
+    }
+
+    if (!ngx_quic_cc_is_default(c)) {
+        ngx_quic_sampler_on_packet_sent(c, f);
+    }
+
+    qc->cc.ops->on_packet_sent(c, f);
+}
+
+
+void
+ngx_quic_cc_on_packet_acked(ngx_connection_t *c, ngx_quic_frame_t *f,
+    size_t prior_in_flight, ngx_msec_t now)
+{
+    ngx_quic_sample_t      sample;
+    ngx_quic_connection_t  *qc;
+
+    if (f->plen == 0) {
+        return;
+    }
+
+    qc = ngx_quic_get_connection(c);
+
+    ngx_quic_sampler_sample_init(&sample);
+    ngx_quic_sampler_on_packet_acked(c, f, &sample);
+    sample.prior_in_flight = prior_in_flight;
+    qc->cc.ops->on_ack_event(c, &sample, now);
+}
+
+
+void
+ngx_quic_cc_on_packet_lost(ngx_connection_t *c, ngx_quic_frame_t *f,
+    size_t prior_in_flight, ngx_msec_t now)
+{
+    ngx_quic_sample_t      sample;
+    ngx_quic_connection_t  *qc;
+
+    if (f->plen == 0) {
+        return;
+    }
+
+    qc = ngx_quic_get_connection(c);
+
+    ngx_quic_sampler_sample_init(&sample);
+    ngx_quic_sampler_on_packet_lost(c, f, &sample);
+    sample.prior_in_flight = prior_in_flight;
+    qc->cc.ops->on_loss_event(c, &sample, now);
+}
+
+
+void
+ngx_quic_cc_on_congestion_event(ngx_connection_t *c, ngx_quic_sample_t *sample,
+    size_t prior_in_flight, ngx_msec_t now)
+{
+    ngx_quic_connection_t  *qc;
+
+    if (sample->acked_bytes == 0 && sample->lost_bytes == 0) {
+        return;
+    }
+
+    qc = ngx_quic_get_connection(c);
+
+    sample->prior_in_flight = prior_in_flight;
+    qc->cc.ops->on_congestion_event(c, sample, now);
+}
+
+
+void
+ngx_quic_cc_on_persistent_congestion(ngx_connection_t *c)
+{
+    ngx_quic_connection_t  *qc;
+
+    qc = ngx_quic_get_connection(c);
+
+    qc->cc.ops->on_persistent_congestion(c);
+}
+
+
+void
+ngx_quic_pacer_init(ngx_quic_pacer_t *p, size_t max_datagram)
+{
+    ngx_memzero(p, sizeof(ngx_quic_pacer_t));
+    p->max_datagram = max_datagram;
+    p->budget = max_datagram * 10;
+}
+
+
+void
+ngx_quic_pacer_set_max_datagram(ngx_quic_pacer_t *p, size_t max_datagram)
+{
+    p->max_datagram = max_datagram;
+}
+
+
+size_t
+ngx_quic_pacer_budget(ngx_quic_pacer_t *p, uint64_t rate, ngx_msec_t now)
+{
+    uint64_t    added, elapsed, budget, burst;
+
+    burst = ngx_quic_pacer_max_burst(p, rate);
+
+    if (p->last == 0) {
+        p->budget = burst;
+        return p->budget;
+    }
+
+    elapsed = now - p->last;
+
+    if (elapsed != 0 && rate > (uint64_t) -1 / elapsed) {
+        added = (uint64_t) NGX_MAX_SIZE_T_VALUE;
+
+    } else {
+        added = rate * elapsed / 1000;
+    }
+
+    budget = p->budget + added;
+
+    if (budget < p->budget || budget > burst) {
+        budget = burst;
+    }
+
+    p->budget = (size_t) budget;
+
+    return p->budget;
+}
+
+
+void
+ngx_quic_pacer_sent(ngx_quic_pacer_t *p, uint64_t rate, ngx_msec_t now,
+    size_t bytes)
+{
+    size_t  budget;
+
+    budget = ngx_quic_pacer_budget(p, rate, now);
+
+    p->budget = (bytes >= budget) ? 0 : budget - bytes;
+    p->last = now;
+}
+
+
+ngx_msec_t
+ngx_quic_pacer_time_until_send(ngx_quic_pacer_t *p, uint64_t rate,
+    ngx_msec_t now)
+{
+    uint64_t  delay, need;
+
+    if (ngx_quic_pacer_budget(p, rate, now) >= p->max_datagram) {
+        return 0;
+    }
+
+    if (rate == 0) {
+        return 1;
+    }
+
+    need = p->max_datagram - p->budget;
+
+    if (need > ((uint64_t) -1 - rate + 1) / 1000) {
+        return NGX_TIMER_INFINITE;
+    }
+
+    delay = (need * 1000 + rate - 1) / rate;
+
+    return ngx_max(delay, 1);
+}
+
+
+void
+ngx_quic_cc_reset_default(ngx_connection_t *c)
+{
+    ngx_quic_connection_t  *qc;
+
+    qc = ngx_quic_get_connection(c);
+    if (qc == NULL) {
+        return;
+    }
+
+    ngx_memzero(&qc->congestion, sizeof(ngx_quic_congestion_t));
+
+    qc->congestion.window = ngx_min(10 * NGX_QUIC_MIN_INITIAL_SIZE,
+                                    ngx_max(2 * NGX_QUIC_MIN_INITIAL_SIZE,
+                                            14720));
+    qc->congestion.ssthresh = (size_t) -1;
+    qc->congestion.mtu = NGX_QUIC_MIN_INITIAL_SIZE;
+    qc->congestion.recovery_start = ngx_current_msec - 1;
+}
+
+
+static ngx_int_t
+ngx_quic_cc_default_init(ngx_connection_t *c)
+{
+    return NGX_OK;
+}
+
+
+static void
+ngx_quic_cc_default_reset_path(ngx_connection_t *c)
+{
+    ngx_quic_cc_reset_default(c);
+}
+
+
+static ngx_uint_t
+ngx_quic_cc_default_can_send(ngx_connection_t *c, size_t bytes_in_flight)
+{
+    ngx_quic_connection_t  *qc;
+
+    qc = ngx_quic_get_connection(c);
+
+    return bytes_in_flight < qc->congestion.window;
+}
+
+
+static ngx_uint_t
+ngx_quic_cc_default_has_pacing_budget(ngx_connection_t *c, ngx_msec_t now)
+{
+    return 1;
+}
+
+
+static size_t
+ngx_quic_cc_default_pacing_budget(ngx_connection_t *c, ngx_msec_t now)
+{
+    return NGX_MAX_SIZE_T_VALUE;
+}
+
+
+static ngx_msec_t
+ngx_quic_cc_default_time_until_send(ngx_connection_t *c, ngx_msec_t now)
+{
+    return 0;
+}
+
+
+static void
+ngx_quic_cc_default_on_packet_sent(ngx_connection_t *c, ngx_quic_frame_t *f)
+{
+}
+
+
+static void
+ngx_quic_cc_default_on_ack_event(ngx_connection_t *c,
+    ngx_quic_sample_t *sample, ngx_msec_t now)
+{
+}
+
+
+static void
+ngx_quic_cc_default_on_loss_event(ngx_connection_t *c,
+    ngx_quic_sample_t *sample, ngx_msec_t now)
+{
+}
+
+
+static void
+ngx_quic_cc_default_on_congestion_event(ngx_connection_t *c,
+    ngx_quic_sample_t *sample, ngx_msec_t now)
+{
+}
+
+
+static size_t
+ngx_quic_cc_default_get_cwnd(ngx_connection_t *c)
+{
+    ngx_quic_connection_t  *qc;
+
+    qc = ngx_quic_get_connection(c);
+
+    return qc->congestion.window;
+}
+
+
+static void
+ngx_quic_cc_default_set_max_datagram_size(ngx_connection_t *c,
+    size_t max_datagram)
+{
+    ngx_quic_connection_t  *qc;
+
+    qc = ngx_quic_get_connection(c);
+
+    qc->congestion.mtu = max_datagram;
+}
+
+
+static void
+ngx_quic_cc_default_on_persistent_congestion(ngx_connection_t *c)
+{
+    ngx_quic_connection_t  *qc;
+
+    qc = ngx_quic_get_connection(c);
+
+    qc->congestion.mtu = qc->path->mtu;
+    qc->congestion.window = qc->congestion.mtu * 2;
+}
+
+
+static size_t
+ngx_quic_pacer_max_burst(ngx_quic_pacer_t *p, uint64_t rate)
+{
+    uint64_t  burst, packets;
+
+    packets = (p->max_datagram > NGX_MAX_SIZE_T_VALUE / 10)
+              ? NGX_MAX_SIZE_T_VALUE : p->max_datagram * 10;
+
+    burst = rate / 250;
+
+    if (burst < packets) {
+        burst = packets;
+    }
+
+    if (burst > NGX_MAX_SIZE_T_VALUE) {
+        return NGX_MAX_SIZE_T_VALUE;
+    }
+
+    return (size_t) burst;
+}
