new file mode 100644
index 000000000..7597c04de
--- /dev/null
+++ b/src/event/quic/ngx_event_quic_sampler.c
@@ -0,0 +1,488 @@
+/*
+ * Copyright (C) Nginx, Inc.
+ */
+
+
+#include <ngx_config.h>
+#include <ngx_core.h>
+#include <ngx_event.h>
+#include <ngx_event_quic_connection.h>
+
+
+static uint64_t ngx_quic_sampler_rate(size_t bytes, ngx_msec_t delta);
+static size_t ngx_quic_sampler_add_size(size_t a, size_t b);
+static uint64_t ngx_quic_sampler_add(uint64_t a, uint64_t b);
+static uint64_t ngx_quic_sampler_mul_div(uint64_t value, uint64_t multiplier,
+    uint64_t divisor);
+static void ngx_quic_sampler_save_state(ngx_quic_frame_t *f,
+    ngx_quic_sample_send_state_t *state);
+
+
+void
+ngx_quic_sampler_init(ngx_connection_t *c)
+{
+    ngx_quic_connection_t  *qc;
+
+    qc = ngx_quic_get_connection(c);
+    if (qc == NULL) {
+        return;
+    }
+
+    if (qc->sampler == NULL) {
+        qc->sampler = ngx_pcalloc(c->pool, sizeof(ngx_quic_sampler_t));
+        if (qc->sampler == NULL) {
+            return;
+        }
+    }
+
+    ngx_memzero(qc->sampler, sizeof(ngx_quic_sampler_t));
+
+    qc->sampler->last_sent_pnum = NGX_QUIC_SAMPLER_INVALID_PNUM;
+    qc->sampler->last_acked_pnum = NGX_QUIC_SAMPLER_INVALID_PNUM;
+    qc->sampler->next_round_pnum = NGX_QUIC_SAMPLER_INVALID_PNUM;
+    qc->sampler->end_app_limited_pnum = NGX_QUIC_SAMPLER_INVALID_PNUM;
+    qc->sampler->ack_height_threshold = 1000;
+}
+
+
+void
+ngx_quic_sampler_reset_path(ngx_connection_t *c)
+{
+    ngx_quic_sampler_init(c);
+}
+
+
+void
+ngx_quic_sampler_sample_init(ngx_quic_sample_t *sample)
+{
+    ngx_memzero(sample, sizeof(ngx_quic_sample_t));
+}
+
+
+void
+ngx_quic_sampler_on_packet_sent(ngx_connection_t *c, ngx_quic_frame_t *f)
+{
+    ngx_quic_sampler_t     *sampler;
+    ngx_quic_connection_t  *qc;
+
+    if (f->plen == 0) {
+        return;
+    }
+
+    qc = ngx_quic_get_connection(c);
+    sampler = qc->sampler;
+
+    sampler->last_sent_pnum = f->pnum;
+    sampler->total_bytes_sent += f->plen;
+
+    if (qc->congestion.in_flight == 0) {
+        sampler->last_acked_ack_time = f->send_time;
+        sampler->last_acked_sent_time = f->send_time;
+        sampler->total_bytes_sent_at_last_ack = sampler->total_bytes_sent;
+    }
+
+    f->sampler_total_sent = sampler->total_bytes_sent;
+    f->sampler_total_acked = sampler->total_bytes_acked;
+    f->sampler_total_lost = sampler->total_bytes_lost;
+    f->sampler_total_sent_at_last_ack =
+        sampler->total_bytes_sent_at_last_ack;
+    f->sampler_in_flight = qc->congestion.in_flight + f->plen;
+    f->sampler_delivered_time = sampler->last_acked_ack_time;
+    f->sampler_last_acked_sent_time = sampler->last_acked_sent_time;
+    f->sampler_last_acked_ack_time = sampler->last_acked_ack_time;
+    f->sampler_app_limited = sampler->app_limited;
+}
+
+
+void
+ngx_quic_sampler_on_packet_acked(ngx_connection_t *c, ngx_quic_frame_t *f,
+    ngx_quic_sample_t *sample)
+{
+    uint64_t                ack_rate, send_rate;
+    ngx_msec_t              now, ack_delta, send_delta, sample_rtt;
+    ngx_quic_sampler_t     *sampler;
+    ngx_quic_sample_send_state_t
+                            state;
+    ngx_quic_connection_t  *qc;
+
+    if (f->plen == 0) {
+        return;
+    }
+
+    qc = ngx_quic_get_connection(c);
+    sampler = qc->sampler;
+    now = ngx_current_msec;
+
+    sampler->total_bytes_acked += f->plen;
+
+    sample->acked_bytes = ngx_quic_sampler_add_size(sample->acked_bytes,
+                                                    f->plen);
+    sample->acked_packets++;
+
+    sample_rtt = now - f->send_time;
+    if (sample->sample_rtt == 0 || sample_rtt < sample->sample_rtt) {
+        sample->sample_rtt = sample_rtt;
+    }
+
+    sample->sample_max_inflight = ngx_max(sample->sample_max_inflight,
+        (size_t) (sampler->total_bytes_acked - f->sampler_total_acked));
+
+    if (sampler->app_limited
+        && (sampler->end_app_limited_pnum == NGX_QUIC_SAMPLER_INVALID_PNUM
+            || f->pnum > sampler->end_app_limited_pnum))
+    {
+        sampler->app_limited = 0;
+    }
+
+    if (sampler->next_round_pnum == NGX_QUIC_SAMPLER_INVALID_PNUM
+        || f->pnum > sampler->next_round_pnum)
+    {
+        sample->round_start = 1;
+        sampler->next_round_pnum = sampler->last_sent_pnum;
+    }
+
+    ack_delta = now - f->sampler_last_acked_ack_time;
+    send_delta = f->send_time - f->sampler_last_acked_sent_time;
+
+    ack_rate = ngx_quic_sampler_rate(
+        (size_t) (sampler->total_bytes_acked - f->sampler_total_acked),
+        ack_delta);
+
+    if (send_delta == 0) {
+        send_rate = (uint64_t) -1;
+
+    } else {
+        send_rate = ngx_quic_sampler_rate(
+            (size_t) (f->sampler_total_sent
+                      - f->sampler_total_sent_at_last_ack),
+            send_delta);
+    }
+
+    if (ack_rate != 0) {
+        ack_rate = (send_rate == (uint64_t) -1)
+                   ? ack_rate : ngx_min(send_rate, ack_rate);
+
+        if (ack_rate > sample->delivery_rate) {
+            sample->send_rate = send_rate;
+            sample->delivery_rate = ack_rate;
+        }
+    }
+
+    if (sample->acked_packets == 1 || f->pnum >= sample->largest_acked) {
+        sample->sample_is_app_limited = f->sampler_app_limited;
+        sample->largest_acked = f->pnum;
+
+        ngx_quic_sampler_save_state(f, &state);
+        sample->last_packet_state = state;
+    }
+
+    sampler->last_acked_pnum = f->pnum;
+    sampler->total_bytes_sent_at_last_ack = f->sampler_total_sent;
+    sampler->last_acked_sent_time = f->send_time;
+    sampler->last_acked_ack_time = now;
+
+    ngx_log_debug8(NGX_LOG_DEBUG_EVENT, c->log, 0,
+                   "quic sampler ack pn:%uL rate:%uL send:%uL rtt:%M"
+                   " acked:%uz if:%uz round:%ui app:%ui",
+                   f->pnum, sample->delivery_rate, sample->send_rate,
+                   sample->sample_rtt, sample->acked_bytes,
+                   f->sampler_in_flight, sample->round_start,
+                   sample->sample_is_app_limited);
+}
+
+
+void
+ngx_quic_sampler_on_packet_lost(ngx_connection_t *c, ngx_quic_frame_t *f,
+    ngx_quic_sample_t *sample)
+{
+    ngx_msec_t              sample_rtt;
+    ngx_quic_sampler_t     *sampler;
+    ngx_quic_sample_send_state_t
+                            state;
+    ngx_quic_connection_t  *qc;
+
+    if (f->plen == 0) {
+        return;
+    }
+
+    qc = ngx_quic_get_connection(c);
+    sampler = qc->sampler;
+
+    sampler->total_bytes_lost += f->plen;
+
+    sample->lost_bytes = ngx_quic_sampler_add_size(sample->lost_bytes,
+                                                   f->plen);
+    sample->lost_packets++;
+
+    sample_rtt = ngx_current_msec - f->send_time;
+    if (sample->sample_rtt == 0 || sample_rtt < sample->sample_rtt) {
+        sample->sample_rtt = sample_rtt;
+    }
+
+    if (sample->acked_packets == 0
+        && (sample->lost_packets == 1 || f->pnum >= sample->largest_acked))
+    {
+        sample->largest_acked = f->pnum;
+
+        ngx_quic_sampler_save_state(f, &state);
+        sample->last_packet_state = state;
+    }
+
+    ngx_log_debug4(NGX_LOG_DEBUG_EVENT, c->log, 0,
+                   "quic sampler lost pn:%uL lost:%uz total:%uL rtt:%M",
+                   f->pnum, sample->lost_bytes,
+                   sampler->total_bytes_lost, sample->sample_rtt);
+}
+
+
+void
+ngx_quic_sampler_on_app_limited(ngx_connection_t *c)
+{
+    ngx_quic_sampler_t     *sampler;
+    ngx_quic_connection_t  *qc;
+
+    qc = ngx_quic_get_connection(c);
+    sampler = qc->sampler;
+
+    sampler->app_limited = 1;
+    sampler->end_app_limited_pnum = sampler->last_sent_pnum;
+}
+
+
+void
+ngx_quic_sampler_enable_overestimate_avoidance(ngx_connection_t *c)
+{
+    ngx_quic_connection_t  *qc;
+
+    qc = ngx_quic_get_connection(c);
+    qc->sampler->ack_height_threshold = 2000;
+}
+
+
+void
+ngx_quic_sampler_set_reduce_extra_acked(ngx_connection_t *c,
+    ngx_uint_t enable)
+{
+    ngx_quic_connection_t  *qc;
+
+    qc = ngx_quic_get_connection(c);
+    qc->sampler->reduce_extra_acked_on_bw_increase = enable;
+}
+
+
+void
+ngx_quic_sampler_reset_ack_height(ngx_connection_t *c, uint64_t round)
+{
+    ngx_quic_sampler_t     *sampler;
+    ngx_quic_ack_height_t  *height;
+    ngx_quic_connection_t  *qc;
+
+    qc = ngx_quic_get_connection(c);
+    if (qc == NULL) {
+        return;
+    }
+
+    sampler = qc->sampler;
+
+    ngx_memzero(sampler->ack_height_filter,
+                sizeof(sampler->ack_height_filter));
+
+    height = &sampler->ack_height_filter[round % NGX_QUIC_ACK_HEIGHT_WINDOW];
+    height->round = round;
+}
+
+
+size_t
+ngx_quic_sampler_max_ack_height(ngx_connection_t *c, uint64_t round)
+{
+    uint64_t                 min_round, max;
+    ngx_uint_t               i;
+    ngx_quic_sampler_t      *sampler;
+    ngx_quic_ack_height_t   *height;
+    ngx_quic_connection_t   *qc;
+
+    qc = ngx_quic_get_connection(c);
+    sampler = qc->sampler;
+
+    max = 0;
+    min_round = (round > NGX_QUIC_ACK_HEIGHT_WINDOW)
+                ? round - NGX_QUIC_ACK_HEIGHT_WINDOW : 0;
+
+    for (i = 0; i < NGX_QUIC_ACK_HEIGHT_WINDOW; i++) {
+        height = &sampler->ack_height_filter[i];
+
+        if (height->round < min_round) {
+            continue;
+        }
+
+        max = ngx_max(max, height->extra_acked);
+    }
+
+    return (size_t) max;
+}
+
+
+size_t
+ngx_quic_sampler_update_ack_height(ngx_connection_t *c, uint64_t bandwidth,
+    ngx_uint_t is_new_max, uint64_t round, ngx_msec_t now)
+{
+    uint64_t                 newly_acked, expected, extra, scaled_acked,
+                             scaled_expected;
+    ngx_msec_t               delta;
+    ngx_quic_sampler_t      *sampler;
+    ngx_quic_ack_height_t   *height;
+    ngx_quic_connection_t   *qc;
+
+    qc = ngx_quic_get_connection(c);
+    sampler = qc->sampler;
+
+    newly_acked = sampler->total_bytes_acked
+                  - sampler->total_bytes_acked_after_last_event;
+
+    if (newly_acked == 0 || bandwidth == 0) {
+        return 0;
+    }
+
+    sampler->total_bytes_acked_after_last_event = sampler->total_bytes_acked;
+
+    if (sampler->reduce_extra_acked_on_bw_increase && is_new_max) {
+        uint64_t             recal_expected;
+        ngx_uint_t           idx;
+        ngx_quic_ack_height_t *h;
+
+        for (idx = 0; idx < NGX_QUIC_ACK_HEIGHT_WINDOW; idx++) {
+            h = &sampler->ack_height_filter[idx];
+            if (h->extra_acked == 0) {
+                continue;
+            }
+
+            recal_expected = ngx_quic_sampler_mul_div(bandwidth, h->delta, 1000);
+
+            if (recal_expected < h->bytes_acked) {
+                h->extra_acked = h->bytes_acked - recal_expected;
+            } else {
+                ngx_memzero(h, sizeof(ngx_quic_ack_height_t));
+            }
+        }
+    }
+
+    if (!sampler->ack_epoch_started) {
+        sampler->ack_epoch_started = 1;
+        sampler->ack_epoch_start = now;
+        sampler->ack_epoch_bytes = newly_acked;
+        return 0;
+    }
+
+    delta = now - sampler->ack_epoch_start;
+    delta = ngx_max(delta, 1);
+    expected = ngx_quic_sampler_mul_div(bandwidth, delta, 1000);
+
+    scaled_acked = ngx_quic_sampler_mul_div(sampler->ack_epoch_bytes,
+                                            1000, 1);
+    scaled_expected = ngx_quic_sampler_mul_div(expected,
+                                               sampler->ack_height_threshold,
+                                               1);
+
+    if (scaled_acked <= scaled_expected) {
+        sampler->ack_epoch_start = now;
+        sampler->ack_epoch_bytes = newly_acked;
+        return 0;
+    }
+
+    sampler->ack_epoch_bytes =
+        ngx_quic_sampler_add(sampler->ack_epoch_bytes, newly_acked);
+
+    extra = (sampler->ack_epoch_bytes > expected)
+            ? sampler->ack_epoch_bytes - expected : 0;
+
+    height = &sampler->ack_height_filter[round % NGX_QUIC_ACK_HEIGHT_WINDOW];
+
+    if (height->round != round || extra > height->extra_acked) {
+        height->round = round;
+        height->extra_acked = extra;
+        height->bytes_acked = sampler->ack_epoch_bytes;
+        height->delta = delta;
+    }
+
+    return (size_t) extra;
+}
+
+
+uint64_t
+ngx_quic_sampler_total_acked(ngx_connection_t *c)
+{
+    ngx_quic_connection_t  *qc;
+
+    qc = ngx_quic_get_connection(c);
+
+    return qc->sampler->total_bytes_acked;
+}
+
+
+static uint64_t
+ngx_quic_sampler_rate(size_t bytes, ngx_msec_t delta)
+{
+    if (bytes == 0) {
+        return 0;
+    }
+
+    if (delta == 0) {
+        delta = 1;
+    }
+
+    if ((uint64_t) bytes > (uint64_t) -1 / 1000) {
+        return (uint64_t) -1;
+    }
+
+    return (uint64_t) bytes * 1000 / delta;
+}
+
+
+static size_t
+ngx_quic_sampler_add_size(size_t a, size_t b)
+{
+    if (a > NGX_MAX_SIZE_T_VALUE - b) {
+        return NGX_MAX_SIZE_T_VALUE;
+    }
+
+    return a + b;
+}
+
+
+static uint64_t
+ngx_quic_sampler_add(uint64_t a, uint64_t b)
+{
+    if (a > (uint64_t) -1 - b) {
+        return (uint64_t) -1;
+    }
+
+    return a + b;
+}
+
+
+static uint64_t
+ngx_quic_sampler_mul_div(uint64_t value, uint64_t multiplier, uint64_t divisor)
+{
+    if (divisor == 0) {
+        return (uint64_t) -1;
+    }
+
+    if (multiplier != 0 && value > (uint64_t) -1 / multiplier) {
+        return (uint64_t) -1;
+    }
+
+    return value * multiplier / divisor;
+}
+
+
+static void
+ngx_quic_sampler_save_state(ngx_quic_frame_t *f,
+    ngx_quic_sample_send_state_t *state)
+{
+    state->valid = 1;
+    state->app_limited = f->sampler_app_limited;
+    state->total_bytes_sent = f->sampler_total_sent;
+    state->total_bytes_acked = f->sampler_total_acked;
+    state->total_bytes_lost = f->sampler_total_lost;
+    state->bytes_in_flight = f->sampler_in_flight;
+}
