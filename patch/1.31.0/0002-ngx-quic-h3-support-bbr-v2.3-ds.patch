+static ngx_int_t
+ngx_quic_bbr_init(ngx_connection_t *c)
+{
+    ngx_quic_bbr_t         *bbr;
+    ngx_quic_connection_t  *qc;
+
+    qc = ngx_quic_get_connection(c);
+
+    bbr = ngx_pcalloc(c->pool, sizeof(ngx_quic_bbr_t));
+    if (bbr == NULL) {
+        return NGX_ERROR;
+    }
+
+    qc->cc.ctx = bbr;
+    ngx_quic_bbr_init_state(c, bbr);
+
+    return NGX_OK;
+}
+
+
+static void
+ngx_quic_bbr_reset_path(ngx_connection_t *c)
+{
+    ngx_quic_connection_t  *qc;
+
+    qc = ngx_quic_get_connection(c);
+
+    ngx_quic_bbr_init_state(c, qc->cc.ctx);
+}
+
+
+static ngx_uint_t
+ngx_quic_bbr_can_send(ngx_connection_t *c, size_t bytes_in_flight)
+{
+    return bytes_in_flight < ngx_quic_bbr_get_cwnd(c);
+}
+
+
+static ngx_uint_t
+ngx_quic_bbr_has_pacing_budget(ngx_connection_t *c, ngx_msec_t now)
+{
+    ngx_quic_bbr_t         *bbr;
+    ngx_quic_connection_t  *qc;
+
+    qc = ngx_quic_get_connection(c);
+    bbr = qc->cc.ctx;
+
+    return ngx_quic_pacer_budget(&qc->cc.pacer, ngx_quic_bbr_rate(bbr), now)
+           >= qc->path->mtu;
+}
+
+
+static size_t
+ngx_quic_bbr_pacing_budget(ngx_connection_t *c, ngx_msec_t now)
+{
+    ngx_quic_bbr_t         *bbr;
+    ngx_quic_connection_t  *qc;
+
+    qc = ngx_quic_get_connection(c);
+    bbr = qc->cc.ctx;
+
+    return ngx_quic_pacer_budget(&qc->cc.pacer, ngx_quic_bbr_rate(bbr), now);
+}
+
+
+static ngx_msec_t
+ngx_quic_bbr_time_until_send(ngx_connection_t *c, ngx_msec_t now)
+{
+    ngx_quic_bbr_t         *bbr;
+    ngx_quic_connection_t  *qc;
+
+    qc = ngx_quic_get_connection(c);
+    bbr = qc->cc.ctx;
+
+    return ngx_quic_pacer_time_until_send(&qc->cc.pacer,
+                                          ngx_quic_bbr_rate(bbr), now);
+}
+
+
+static void
+ngx_quic_bbr_on_packet_sent(ngx_connection_t *c, ngx_quic_frame_t *f)
+{
+    ngx_quic_bbr_t         *bbr;
+    ngx_quic_connection_t  *qc;
+
+    qc = ngx_quic_get_connection(c);
+    bbr = qc->cc.ctx;
+
+    if (qc->congestion.in_flight == 0) {
+        bbr->exiting_quiescence = 1;
+    }
+
+    bbr->last_sent_packet = f->pnum;
+
+    ngx_quic_pacer_sent(&qc->cc.pacer, ngx_quic_bbr_rate(bbr),
+                        f->send_time, f->plen);
+}
+
+
+static void
+ngx_quic_bbr_on_ack_event(ngx_connection_t *c, ngx_quic_sample_t *sample,
+    ngx_msec_t now)
+{
+    ngx_quic_bbr_update_control(c, sample, now, 0);
+}
+
+
+static void
+ngx_quic_bbr_on_loss_event(ngx_connection_t *c, ngx_quic_sample_t *sample,
+    ngx_msec_t now)
+{
+    ngx_quic_bbr_update_control(c, sample, now, 1);
+}
+
+
+static void
+ngx_quic_bbr_on_congestion_event(ngx_connection_t *c,
+    ngx_quic_sample_t *sample, ngx_msec_t now)
+{
+    ngx_quic_bbr_update_control(c, sample, now, sample->lost_bytes != 0);
+}
+
+
+static size_t
+ngx_quic_bbr_get_cwnd(ngx_connection_t *c)
+{
+    size_t                  cwnd;
+    ngx_quic_bbr_t         *bbr;
+    ngx_quic_connection_t  *qc;
+
+    qc = ngx_quic_get_connection(c);
+    bbr = qc->cc.ctx;
+
+    if (bbr->mode == NGX_QUIC_BBR_PROBE_RTT) {
+        return bbr->min_cwnd;
+    }
+
+    cwnd = bbr->cwnd;
+
+    if (bbr->recovery_state != NGX_QUIC_BBR_RECOVERY_NONE) {
+        cwnd = ngx_min(cwnd, bbr->recovery_window);
+    }
+
+    return ngx_quic_bbr_clamp_cwnd(bbr, cwnd);
+}
+
+
+static void
+ngx_quic_bbr_set_max_datagram_size(ngx_connection_t *c, size_t max_datagram)
+{
+    ngx_quic_bbr_t         *bbr;
+    ngx_quic_connection_t  *qc;
+
+    qc = ngx_quic_get_connection(c);
+    bbr = qc->cc.ctx;
+
+    if (max_datagram == 0 || max_datagram == bbr->max_datagram) {
+        return;
+    }
+
+    bbr->initial_cwnd = ngx_quic_bbr_rescale_window(bbr->initial_cwnd,
+                                                    bbr->max_datagram,
+                                                    max_datagram);
+    bbr->min_cwnd = 4 * max_datagram;
+    bbr->cwnd_to_calculate_min_pacing_rate =
+        ngx_quic_bbr_rescale_window(bbr->cwnd_to_calculate_min_pacing_rate,
+                                    bbr->max_datagram, max_datagram);
+
+    if (bbr->max_cwnd != NGX_MAX_SIZE_T_VALUE) {
+        bbr->max_cwnd = ngx_quic_bbr_rescale_window(bbr->max_cwnd,
+                                                    bbr->max_datagram,
+                                                    max_datagram);
+    }
+
+    bbr->cwnd = ngx_quic_bbr_clamp_cwnd(bbr, bbr->cwnd);
+    bbr->recovery_window = ngx_quic_bbr_clamp_cwnd(bbr,
+                                                   bbr->recovery_window);
+    bbr->max_datagram = max_datagram;
+    qc->congestion.window = ngx_quic_bbr_get_cwnd(c);
+}
+
+
+static void
+ngx_quic_bbr_on_persistent_congestion(ngx_connection_t *c)
+{
+    ngx_quic_bbr_t         *bbr;
+    ngx_quic_connection_t  *qc;
+
+    qc = ngx_quic_get_connection(c);
+    bbr = qc->cc.ctx;
+
+    bbr->is_at_full_bandwidth = 1;
+    bbr->recovery_state = NGX_QUIC_BBR_RECOVERY_CONSERVATION;
+    bbr->recovery_window = bbr->min_cwnd;
+    bbr->cwnd = bbr->min_cwnd;
+
+    qc->congestion.window = ngx_quic_bbr_get_cwnd(c);
+}
+
+
+static void
+ngx_quic_bbr_init_state(ngx_connection_t *c, ngx_quic_bbr_t *bbr)
+{
+    ngx_quic_connection_t  *qc;
+
+    qc = ngx_quic_get_connection(c);
+
+    ngx_memzero(bbr, sizeof(ngx_quic_bbr_t));
+
+    bbr->max_bw_filter.window_length = NGX_QUIC_BBR_BW_WINDOW;
+
+    ngx_quic_cc_reset_default(c);
+    ngx_quic_bbr_set_profile(c, bbr);
+
+    bbr->min_rtt = NGX_TIMER_INFINITE;
+    bbr->min_rtt_stamp = ngx_current_msec;
+    bbr->last_sent_packet = NGX_QUIC_BBR_INVALID_PNUM;
+    bbr->current_round_end = NGX_QUIC_BBR_INVALID_PNUM;
+    bbr->end_recovery_at = NGX_QUIC_BBR_INVALID_PNUM;
+
+    bbr->max_datagram = ngx_max(qc->path->mtu, NGX_QUIC_MIN_INITIAL_SIZE);
+    bbr->initial_cwnd = 32 * bbr->max_datagram;
+    bbr->min_cwnd = 4 * bbr->max_datagram;
+    bbr->max_cwnd = NGX_MAX_SIZE_T_VALUE;
+    bbr->cwnd = bbr->initial_cwnd;
+    bbr->recovery_window = bbr->max_cwnd;
+    bbr->cwnd_to_calculate_min_pacing_rate = bbr->initial_cwnd;
+    /* initial pacing from initial_cwnd / 100ms * high_gain, matching quic-go BBR */
+    bbr->pacing_rate = (uint64_t) bbr->initial_cwnd * 10
+                       * bbr->high_gain / NGX_QUIC_BBR_SCALE;
+
+    ngx_quic_bbr_enter_startup(bbr);
+
+    qc->congestion.window = bbr->cwnd;
+    qc->congestion.ssthresh = (size_t) -1;
+
+    ngx_quic_pacer_init(&qc->cc.pacer, bbr->max_datagram);
+
+    ngx_log_debug4(NGX_LOG_DEBUG_EVENT, c->log, 0,
+                   "quic bbr init profile:%ui cwnd:%uz rate:%uL gain:%ui",
+                   bbr->profile, bbr->cwnd, bbr->pacing_rate,
+                   bbr->high_gain);
+}
+
+
+static void
+ngx_quic_bbr_set_profile(ngx_connection_t *c, ngx_quic_bbr_t *bbr)
+{
+    ngx_quic_connection_t  *qc;
+
+    qc = ngx_quic_get_connection(c);
+    bbr->profile = qc->conf->bbr_profile;
+
+    switch (qc->conf->bbr_profile) {
+    case NGX_QUIC_BBR_PROFILE_CONSERVATIVE:
+        bbr->high_gain = 2250;
+        bbr->high_cwnd_gain = 1750;
+        bbr->cwnd_gain = 1750;
+        bbr->num_startup_rtts = 2;
+        bbr->bytes_lost_multiplier = 1;
+        bbr->detect_overshooting = 1;
+        bbr->drain_to_target = 1;
+        ngx_quic_sampler_enable_overestimate_avoidance(c);
+        ngx_quic_sampler_set_reduce_extra_acked(c, 1);
+        break;
+
+    case NGX_QUIC_BBR_PROFILE_AGGRESSIVE:
+        bbr->high_gain = 3000;
+        bbr->high_cwnd_gain = 2250;
+        bbr->cwnd_gain = 2500;
+        bbr->num_startup_rtts = 4;
+        bbr->bytes_lost_multiplier = 2;
+        bbr->enable_ack_aggregation_startup = 1;
+        bbr->expire_ack_aggregation_startup = 1;
+        break;
+
+    default:
+        bbr->high_gain = 2885;
+        bbr->high_cwnd_gain = 2000;
+        bbr->cwnd_gain = 2000;
+        bbr->num_startup_rtts = 3;
+        bbr->bytes_lost_multiplier = 2;
+        break;
+    }
+
+    bbr->drain_gain = NGX_QUIC_BBR_SCALE * NGX_QUIC_BBR_SCALE
+                      / bbr->high_gain;
+}
+
+
+static void
+ngx_quic_bbr_filter_reset(ngx_quic_bbr_max_filter_t *f, uint64_t sample,
+    uint64_t time)
+{
+    f->est[2].sample = sample;
+    f->est[2].time = time;
+    f->est[1] = f->est[2];
+    f->est[0] = f->est[1];
+}
+
+
+static void
+ngx_quic_bbr_filter_update(ngx_quic_bbr_max_filter_t *f, uint64_t sample,
+    uint64_t time)
+{
+    /* uninitialized, new best, or oldest estimate expired → reset all */
+    if (f->est[0].sample == 0
+        || sample >= f->est[0].sample
+        || time - f->est[2].time > f->window_length)
+    {
+        ngx_quic_bbr_filter_reset(f, sample, time);
+        return;
+    }
+
+    if (sample >= f->est[1].sample) {
+        f->est[1].sample = sample;
+        f->est[1].time = time;
+        f->est[2] = f->est[1];
+
+    } else if (sample >= f->est[2].sample) {
+        f->est[2].sample = sample;
+        f->est[2].time = time;
+    }
+
+    /* expire best estimate after a full window */
+    if (time - f->est[0].time > f->window_length) {
+        f->est[0] = f->est[1];
+        f->est[1] = f->est[2];
+        f->est[2].sample = sample;
+        f->est[2].time = time;
+
+        if (time - f->est[0].time > f->window_length) {
+            f->est[0] = f->est[1];
+            f->est[1] = f->est[2];
+        }
+        return;
+    }
+
+    /* second-best: take from 2nd quarter of window if no better sample */
+    if (f->est[1].sample == f->est[0].sample
+        && time - f->est[1].time > f->window_length / 4)
+    {
+        f->est[1].sample = sample;
+        f->est[1].time = time;
+        f->est[2] = f->est[1];
+        return;
+    }
+
+    /* third-best: take from 2nd half of window if no better sample */
+    if (f->est[2].sample == f->est[1].sample
+        && time - f->est[2].time > f->window_length / 2)
+    {
+        f->est[2].sample = sample;
+        f->est[2].time = time;
+    }
+}
+
+
+static uint64_t
+ngx_quic_bbr_filter_best(ngx_quic_bbr_max_filter_t *f)
+{
+    return f->est[0].sample;
+}
+
+
+static uint64_t
+ngx_quic_bbr_max_bw(ngx_quic_bbr_t *bbr)
+{
+    return ngx_quic_bbr_filter_best(&bbr->max_bw_filter);
+}
+
+
+static ngx_uint_t
+ngx_quic_bbr_update_bw(ngx_quic_bbr_t *bbr, ngx_quic_sample_t *sample)
+{
+    uint64_t  old;
+
+    if (sample->delivery_rate == 0) {
+        return 0;
+    }
+
+    old = bbr->max_bw;
+
+    if (!sample->sample_is_app_limited || sample->delivery_rate >= old) {
+        ngx_quic_bbr_filter_update(&bbr->max_bw_filter,
+                                   sample->delivery_rate, bbr->round_count);
+        bbr->max_bw = ngx_quic_bbr_max_bw(bbr);
+    }
+
+    return bbr->max_bw > old;
+}
+
+
+static size_t
+ngx_quic_bbr_target_cwnd(ngx_quic_bbr_t *bbr, ngx_uint_t gain)
+{
+    uint64_t  target;
+
+    if (bbr->max_bw == 0 || bbr->min_rtt == NGX_TIMER_INFINITE) {
+        target = bbr->initial_cwnd;
+
+    } else {
+        if (bbr->max_bw > (uint64_t) NGX_MAX_SIZE_T_VALUE / bbr->min_rtt) {
+            return bbr->max_cwnd;
+        }
+
+        target = bbr->max_bw * bbr->min_rtt / 1000;
+    }
+
+    if (target > (uint64_t) NGX_MAX_SIZE_T_VALUE / gain) {
+        return bbr->max_cwnd;
+    }
+
+    target = target * gain / NGX_QUIC_BBR_SCALE;
+    target = ngx_max(target, bbr->min_cwnd);
+    target = ngx_min(target, bbr->max_cwnd);
+
+    return (size_t) target;
+}
+
+
+static void
+ngx_quic_bbr_enter_startup(ngx_quic_bbr_t *bbr)
+{
+    bbr->mode = NGX_QUIC_BBR_STARTUP;
+    bbr->pacing_gain = bbr->high_gain;
+    bbr->congestion_window_gain = bbr->high_cwnd_gain;
+}
+
+
+static void
+ngx_quic_bbr_enter_probe_bw(ngx_quic_bbr_t *bbr, ngx_msec_t now)
+{
+    static ngx_uint_t       gains[8] = {
+        1250, 750, 1000, 1000, 1000, 1000, 1000, 1000
+    };
+
+    bbr->mode = NGX_QUIC_BBR_PROBE_BW;
+    bbr->congestion_window_gain = bbr->cwnd_gain;
+
+    bbr->cycle_index = ngx_random() % 7;
+    if (bbr->cycle_index >= 1) {
+        bbr->cycle_index++;
+    }
+
+    bbr->cycle_stamp = now;
+    bbr->pacing_gain = gains[bbr->cycle_index];
+}
+
+
+static void
+ngx_quic_bbr_maybe_app_limited(ngx_connection_t *c, ngx_quic_bbr_t *bbr,
+    size_t prior_in_flight)
+{
+    if (prior_in_flight < ngx_quic_bbr_target_cwnd(bbr, NGX_QUIC_BBR_SCALE)) {
+        ngx_quic_sampler_on_app_limited(c);
+    }
+}
+
+
+static void
+ngx_quic_bbr_check_full_bw(ngx_connection_t *c, ngx_quic_bbr_t *bbr,
+    ngx_quic_sample_t *sample)
+{
+    uint64_t  target;
+
+    if (bbr->last_sample_is_app_limited) {
+        return;
+    }
+
+    target = bbr->full_bw * 125 / 100;
+
+    if (bbr->max_bw >= target) {
+        bbr->full_bw = bbr->max_bw;
+        bbr->rounds_without_bw_gain = 0;
+
+        if (bbr->expire_ack_aggregation_startup) {
+            ngx_quic_sampler_reset_ack_height(c, bbr->round_count);
+        }
+
+        return;
+    }
+
+    bbr->rounds_without_bw_gain++;
+
+    if (bbr->rounds_without_bw_gain >= bbr->num_startup_rtts
+        || ngx_quic_bbr_should_exit_startup_due_to_loss(bbr, sample))
+    {
+        bbr->is_at_full_bandwidth = 1;
+    }
+}
+
+
+static ngx_uint_t
+ngx_quic_bbr_should_exit_startup_due_to_loss(ngx_quic_bbr_t *bbr,
+    ngx_quic_sample_t *sample)
+{
+    size_t  inflight;
+
+    if (bbr->num_loss_events_in_round < NGX_QUIC_BBR_STARTUP_LOSS_EVENTS
+        || !sample->last_packet_state.valid)
+    {
+        return 0;
+    }
+
+    inflight = sample->last_packet_state.bytes_in_flight;
+
+    return inflight != 0
+           && bbr->bytes_lost_in_round
+              > inflight * NGX_QUIC_BBR_LOSS_THRESHOLD / 1000;
+}
+
+
+static void
+ngx_quic_bbr_maybe_exit_startup_or_drain(ngx_connection_t *c,
+    ngx_quic_bbr_t *bbr, ngx_msec_t now)
+{
+    ngx_quic_connection_t  *qc;
+
+    qc = ngx_quic_get_connection(c);
+
+    if (bbr->mode == NGX_QUIC_BBR_STARTUP && bbr->is_at_full_bandwidth) {
+        bbr->mode = NGX_QUIC_BBR_DRAIN;
+        bbr->pacing_gain = bbr->drain_gain;
+        bbr->congestion_window_gain = bbr->high_cwnd_gain;
+    }
+
+    if (bbr->mode == NGX_QUIC_BBR_DRAIN
+        && qc->congestion.in_flight
+           <= ngx_quic_bbr_target_cwnd(bbr, NGX_QUIC_BBR_SCALE))
+    {
+        ngx_quic_bbr_enter_probe_bw(bbr, now);
+    }
+}
+
+
+static void
+ngx_quic_bbr_maybe_probe_rtt(ngx_connection_t *c, ngx_quic_bbr_t *bbr,
+    ngx_quic_sample_t *sample, ngx_msec_t now, ngx_uint_t min_rtt_expired)
+{
+    ngx_quic_connection_t  *qc;
+
+    qc = ngx_quic_get_connection(c);
+
+    if (min_rtt_expired && !bbr->exiting_quiescence
+        && bbr->mode != NGX_QUIC_BBR_PROBE_RTT)
+    {
+        bbr->mode = NGX_QUIC_BBR_PROBE_RTT;
+        bbr->pacing_gain = NGX_QUIC_BBR_SCALE;
+        bbr->probe_rtt_done_stamp = 0;
+        bbr->probe_rtt_round_passed = 0;
+    }
+
+    if (bbr->mode != NGX_QUIC_BBR_PROBE_RTT) {
+        bbr->exiting_quiescence = 0;
+        return;
+    }
+
+    ngx_quic_sampler_on_app_limited(c);
+
+    if (bbr->probe_rtt_done_stamp == 0) {
+        if (qc->congestion.in_flight < bbr->min_cwnd + bbr->max_datagram) {
+            bbr->probe_rtt_done_stamp = now + NGX_QUIC_BBR_PROBE_RTT_TIME;
+            bbr->probe_rtt_round_passed = 0;
+        }
+
+    } else {
+        if (sample->round_start) {
+            bbr->probe_rtt_round_passed = 1;
+        }
+
+        if ((ngx_msec_int_t) (now - bbr->probe_rtt_done_stamp) >= 0
+            && bbr->probe_rtt_round_passed)
+        {
+            bbr->min_rtt_stamp = now;
+
+            if (!bbr->is_at_full_bandwidth) {
+                ngx_quic_bbr_enter_startup(bbr);
+
+            } else {
+                ngx_quic_bbr_enter_probe_bw(bbr, now);
+            }
+        }
+    }
+
+    bbr->exiting_quiescence = 0;
+}
+
+
+static void
+ngx_quic_bbr_update_gain_cycle(ngx_connection_t *c, ngx_quic_bbr_t *bbr,
+    ngx_msec_t now, size_t prior_in_flight, ngx_uint_t has_losses)
+{
+    static ngx_uint_t       gains[8] = {
+        1250, 750, 1000, 1000, 1000, 1000, 1000, 1000
+    };
+
+    ngx_uint_t              advance;
+    ngx_quic_connection_t  *qc;
+
+    qc = ngx_quic_get_connection(c);
+
+    if (bbr->mode != NGX_QUIC_BBR_PROBE_BW
+        || bbr->min_rtt == NGX_TIMER_INFINITE)
+    {
+        return;
+    }
+
+    advance = now - bbr->cycle_stamp >= bbr->min_rtt;
+
+    if (bbr->pacing_gain > NGX_QUIC_BBR_SCALE && !has_losses
+        && prior_in_flight < ngx_quic_bbr_target_cwnd(bbr, bbr->pacing_gain))
+    {
+        advance = 0;
+    }
+
+    if (bbr->pacing_gain < NGX_QUIC_BBR_SCALE
+        && qc->congestion.in_flight
+           <= ngx_quic_bbr_target_cwnd(bbr, NGX_QUIC_BBR_SCALE))
+    {
+        advance = 1;
+    }
+
+    if (!advance) {
+        return;
+    }
+
+    bbr->cycle_index = (bbr->cycle_index + 1) % 8;
+    bbr->cycle_stamp = now;
+
+    if (bbr->drain_to_target && bbr->pacing_gain < NGX_QUIC_BBR_SCALE
+        && gains[bbr->cycle_index] == NGX_QUIC_BBR_SCALE
+        && qc->congestion.in_flight
+           > ngx_quic_bbr_target_cwnd(bbr, NGX_QUIC_BBR_SCALE))
+    {
+        return;
+    }
+
+    bbr->pacing_gain = gains[bbr->cycle_index];
+}
+
+
+static void
+ngx_quic_bbr_update_recovery_state(ngx_quic_bbr_t *bbr,
+    ngx_quic_sample_t *sample, ngx_uint_t has_losses)
+{
+    if (!bbr->is_at_full_bandwidth) {
+        return;
+    }
+
+    if (has_losses) {
+        if (bbr->last_sent_packet != NGX_QUIC_BBR_INVALID_PNUM) {
+            bbr->end_recovery_at = bbr->last_sent_packet;
+        }
+    }
+
+    switch (bbr->recovery_state) {
+    case NGX_QUIC_BBR_RECOVERY_NONE:
+        if (has_losses) {
+            bbr->recovery_state = NGX_QUIC_BBR_RECOVERY_CONSERVATION;
+            bbr->recovery_window = 0;
+            bbr->current_round_end = bbr->last_sent_packet;
+        }
+        break;
+
+    case NGX_QUIC_BBR_RECOVERY_CONSERVATION:
+        if (sample->round_start
+            || (bbr->current_round_end != NGX_QUIC_BBR_INVALID_PNUM
+                && sample->largest_acked > bbr->current_round_end))
+        {
+            bbr->recovery_state = NGX_QUIC_BBR_RECOVERY_GROWTH;
+            bbr->current_round_end = NGX_QUIC_BBR_INVALID_PNUM;
+        }
+        /* fall through */
+
+    case NGX_QUIC_BBR_RECOVERY_GROWTH:
+        if (!has_losses
+            && bbr->end_recovery_at != NGX_QUIC_BBR_INVALID_PNUM
+            && sample->largest_acked > bbr->end_recovery_at)
+        {
+            bbr->recovery_state = NGX_QUIC_BBR_RECOVERY_NONE;
+        }
+        break;
+    }
+}
+
+
+static void
+ngx_quic_bbr_calculate_pacing_rate(ngx_quic_bbr_t *bbr, size_t bytes_lost)
+{
+    uint64_t         min_rate, target;
+    ngx_msec_t      rtt;
+
+    if (bbr->max_bw == 0) {
+        return;
+    }
+
+    target = ngx_quic_bbr_scale_bw(bbr->max_bw, bbr->pacing_gain);
+    target = ngx_max(target, NGX_QUIC_BBR_MIN_BW);
+
+    if (bbr->is_at_full_bandwidth) {
+        bbr->pacing_rate = target;
+        return;
+    }
+
+    if (bbr->detect_overshooting && bytes_lost != 0) {
+        bbr->bytes_lost_while_detecting_overshooting += bytes_lost;
+
+        if (bbr->pacing_rate > target
+            && (bbr->has_non_app_limited_sample
+                || bbr->bytes_lost_while_detecting_overshooting
+                   * bbr->bytes_lost_multiplier > bbr->initial_cwnd))
+        {
+            rtt = ngx_max(bbr->min_rtt == NGX_TIMER_INFINITE
+                          ? 0 : bbr->min_rtt, 1);
+            min_rate = bbr->cwnd_to_calculate_min_pacing_rate * 1000 / rtt;
+            bbr->pacing_rate = ngx_max(target, min_rate);
+            bbr->bytes_lost_while_detecting_overshooting = 0;
+            bbr->detect_overshooting = 0;
+        }
+    }
+
+    bbr->pacing_rate = ngx_max(bbr->pacing_rate, target);
+}
+
+
+static void
+ngx_quic_bbr_calculate_cwnd(ngx_connection_t *c, ngx_quic_bbr_t *bbr,
+    ngx_quic_sample_t *sample)
+{
+    size_t  target;
+
+    if (sample->acked_bytes == 0 || bbr->mode == NGX_QUIC_BBR_PROBE_RTT) {
+        return;
+    }
+
+    target = ngx_quic_bbr_target_cwnd(bbr, bbr->congestion_window_gain);
+
+    if (bbr->is_at_full_bandwidth) {
+        target = ngx_quic_bbr_add_window(target,
+                  ngx_quic_sampler_max_ack_height(c, bbr->round_count));
+
+    } else if (bbr->enable_ack_aggregation_startup) {
+        target = ngx_quic_bbr_add_window(target, sample->extra_acked);
+    }
+
+    if (bbr->is_at_full_bandwidth) {
+        bbr->cwnd = ngx_min(target, ngx_quic_bbr_add_window(bbr->cwnd,
+                                                            sample->acked_bytes));
+
+    } else if (bbr->cwnd < target
+               || ngx_quic_sampler_total_acked(c) < bbr->initial_cwnd)
+    {
+        bbr->cwnd = ngx_quic_bbr_add_window(bbr->cwnd, sample->acked_bytes);
+    }
+
+    bbr->cwnd = ngx_quic_bbr_clamp_cwnd(bbr, bbr->cwnd);
+}
+
+
+static void
+ngx_quic_bbr_calculate_recovery_window(ngx_quic_bbr_t *bbr,
+    size_t bytes_acked, size_t bytes_lost, size_t bytes_in_flight)
+{
+    if (bbr->recovery_state == NGX_QUIC_BBR_RECOVERY_NONE) {
+        return;
+    }
+
+    if (bbr->recovery_window == 0) {
+        bbr->recovery_window = ngx_max(bbr->min_cwnd,
+            ngx_quic_bbr_add_window(bytes_in_flight, bytes_acked));
+        return;
+    }
+
+    if (bbr->recovery_window >= bytes_lost) {
+        bbr->recovery_window -= bytes_lost;
+
+    } else {
+        bbr->recovery_window = bbr->max_datagram;
+    }
+
+    if (bbr->recovery_state == NGX_QUIC_BBR_RECOVERY_GROWTH) {
+        bbr->recovery_window =
+            ngx_quic_bbr_add_window(bbr->recovery_window, bytes_acked);
+    }
+
+    bbr->recovery_window = ngx_max(bbr->recovery_window,
+        ngx_quic_bbr_add_window(bytes_in_flight, bytes_acked));
+    bbr->recovery_window = ngx_quic_bbr_clamp_cwnd(bbr,
+                                                   bbr->recovery_window);
+}
+
+
+static void
+ngx_quic_bbr_update_control(ngx_connection_t *c, ngx_quic_sample_t *sample,
+    ngx_msec_t now, ngx_uint_t has_losses)
+{
+    ngx_uint_t              is_new_max, min_rtt_expired;
+    ngx_quic_bbr_t         *bbr;
+    ngx_quic_connection_t  *qc;
+
+    qc = ngx_quic_get_connection(c);
+    bbr = qc->cc.ctx;
+
+    ngx_quic_bbr_maybe_app_limited(c, bbr, sample->prior_in_flight);
+
+    min_rtt_expired = bbr->min_rtt != NGX_TIMER_INFINITE
+                      && now - bbr->min_rtt_stamp
+                         > NGX_QUIC_BBR_MIN_RTT_EXPIRY;
+
+    if (sample->sample_rtt != 0
+        && (bbr->min_rtt == NGX_TIMER_INFINITE
+            || sample->sample_rtt < bbr->min_rtt
+            || min_rtt_expired))
+    {
+        bbr->min_rtt = sample->sample_rtt;
+        bbr->min_rtt_stamp = now;
+    }
+
+    if (sample->last_packet_state.valid) {
+        bbr->last_sample_is_app_limited =
+            sample->last_packet_state.app_limited;
+
+        if (!bbr->last_sample_is_app_limited) {
+            bbr->has_non_app_limited_sample = 1;
+        }
+    }
+
+    if (sample->round_start) {
+        bbr->round_count++;
+        bbr->num_loss_events_in_round = 0;
+        bbr->bytes_lost_in_round = 0;
+    }
+
+    if (has_losses) {
+        bbr->num_loss_events_in_round++;
+        bbr->bytes_lost_in_round += sample->lost_bytes;
+    }
+
+    is_new_max = ngx_quic_bbr_update_bw(bbr, sample);
+    sample->extra_acked = ngx_quic_sampler_update_ack_height(c,
+                         bbr->max_bw, is_new_max, bbr->round_count, now);
+
+    if (sample->round_start
+        && bbr->mode == NGX_QUIC_BBR_STARTUP
+        && !bbr->is_at_full_bandwidth)
+    {
+        ngx_quic_bbr_check_full_bw(c, bbr, sample);
+    }
+
+    ngx_quic_bbr_update_recovery_state(bbr, sample, has_losses);
+    ngx_quic_bbr_update_gain_cycle(c, bbr, now, sample->prior_in_flight,
+                                   has_losses);
+    ngx_quic_bbr_maybe_exit_startup_or_drain(c, bbr, now);
+    ngx_quic_bbr_maybe_probe_rtt(c, bbr, sample, now, min_rtt_expired);
+    ngx_quic_bbr_calculate_pacing_rate(bbr, sample->lost_bytes);
+    ngx_quic_bbr_calculate_cwnd(c, bbr, sample);
+    ngx_quic_bbr_calculate_recovery_window(bbr, sample->acked_bytes,
+                                           sample->lost_bytes,
+                                           qc->congestion.in_flight);
+
+    qc->congestion.window = ngx_quic_bbr_get_cwnd(c);
+
+    ngx_log_debug8(NGX_LOG_DEBUG_EVENT, c->log, 0,
+                   "quic bbr event mode:%ui profile:%ui rate:%uL bw:%uL"
+                   " cwnd:%uz if:%uz rtt:%M round:%uL",
+                   bbr->mode, bbr->profile, bbr->pacing_rate, bbr->max_bw,
+                   qc->congestion.window, qc->congestion.in_flight,
+                   bbr->min_rtt, bbr->round_count);
+}
+
+
+static uint64_t
+ngx_quic_bbr_scale_bw(uint64_t bw, ngx_uint_t gain)
+{
+    if (bw > (uint64_t) -1 / gain) {
+        return (uint64_t) -1 / NGX_QUIC_BBR_SCALE;
+    }
+
+    return bw * gain / NGX_QUIC_BBR_SCALE;
+}
+
+
+static uint64_t
+ngx_quic_bbr_rate(ngx_quic_bbr_t *bbr)
+{
+    return ngx_max(bbr->pacing_rate, NGX_QUIC_BBR_MIN_BW);
+}
+
+
+static size_t
+ngx_quic_bbr_rescale_window(size_t window, size_t old_size, size_t new_size)
+{
+    uint64_t  scaled;
+
+    if (old_size == 0 || old_size == new_size) {
+        return window;
+    }
+
+    if ((uint64_t) window > (uint64_t) NGX_MAX_SIZE_T_VALUE / new_size) {
+        return NGX_MAX_SIZE_T_VALUE;
+    }
+
+    scaled = (uint64_t) window * new_size / old_size;
+
+    return (scaled > NGX_MAX_SIZE_T_VALUE) ? NGX_MAX_SIZE_T_VALUE
+                                           : (size_t) scaled;
+}
+
+
+static size_t
+ngx_quic_bbr_clamp_cwnd(ngx_quic_bbr_t *bbr, size_t cwnd)
+{
+    cwnd = ngx_max(cwnd, bbr->min_cwnd);
+    cwnd = ngx_min(cwnd, bbr->max_cwnd);
+
+    return cwnd;
+}
+
+
+static size_t
+ngx_quic_bbr_add_window(size_t a, size_t b)
+{
+    if (a > NGX_MAX_SIZE_T_VALUE - b) {
+        return NGX_MAX_SIZE_T_VALUE;
+    }
+
+    return a + b;
+}
