     send_time.newest = NGX_TIMER_INFINITE;
 
-    if (ngx_quic_handle_ack_frame_range(c, ctx, min, max, &send_time)
+    ngx_quic_cc_event_init(c, &cc_event);
+
+    if (ngx_quic_handle_ack_frame_range(c, ctx, min, max, &send_time,
+                                        &cc_event)
         != NGX_OK)
     {
         return NGX_ERROR;
@@ -194,14 +270,21 @@ ngx_quic_handle_ack_frame(ngx_connection_t *c, ngx_quic_header_t *pkt,
 
         min = max - range;
 
-        if (ngx_quic_handle_ack_frame_range(c, ctx, min, max, &send_time)
+        if (ngx_quic_handle_ack_frame_range(c, ctx, min, max, &send_time,
+                                            &cc_event)
             != NGX_OK)
         {
             return NGX_ERROR;
         }
     }
 
-    return ngx_quic_detect_lost(c, &send_time);
+    if (ngx_quic_detect_lost(c, &send_time, &cc_event) != NGX_OK) {
+        return NGX_ERROR;
