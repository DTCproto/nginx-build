+static char *
+ngx_http_quic_brutal_up(ngx_conf_t *cf, ngx_command_t *cmd, void *conf)
+{
+    char  *p = conf;
+
+    u_char     *unit;
+    size_t     *sp, factor, nlen;
+    ssize_t     n;
+    ngx_str_t  *value;
+
+    sp = (size_t *) (p + cmd->offset);
+
+    if (*sp != NGX_CONF_UNSET_SIZE) {
+        return "is duplicate";
+    }
+
+    value = cf->args->elts;
+
+    if (value[1].len <= 4) {
+        goto invalid;
+    }
+
+    unit = value[1].data + value[1].len - 4;
+    nlen = value[1].len - 4;
+
+    n = ngx_atosz(value[1].data, nlen);
+    if (n == NGX_ERROR || n == 0) {
+        goto invalid;
+    }
+
+    if (ngx_strncmp(unit, "kbps", 4) == 0) {
+        factor = 125;
+
+    } else if (ngx_strncmp(unit, "mbps", 4) == 0) {
+        factor = 125000;
+
+    } else if (ngx_strncmp(unit, "gbps", 4) == 0) {
+        factor = 125000000;
+
+    } else if (ngx_strncmp(unit, "KBps", 4) == 0) {
+        factor = 1000;
+
+    } else if (ngx_strncmp(unit, "MBps", 4) == 0) {
+        factor = 1000000;
+
+    } else if (ngx_strncmp(unit, "GBps", 4) == 0) {
+        factor = 1000000000;
+
+    } else {
+        goto invalid;
+    }
+
+    if ((size_t) n > NGX_MAX_SIZE_T_VALUE / factor) {
+        ngx_conf_log_error(NGX_LOG_EMERG, cf, 0,
+                           "quic_brutal_up value \"%V\" is too large",
+                           &value[1]);
+        return NGX_CONF_ERROR;
+    }
+
+    *sp = (size_t) n * factor;
+
+    return NGX_CONF_OK;
+
+invalid:
+
+    ngx_conf_log_error(NGX_LOG_EMERG, cf, 0,
+                       "invalid quic_brutal_up value \"%V\"", &value[1]);
+
+    return NGX_CONF_ERROR;
+}
