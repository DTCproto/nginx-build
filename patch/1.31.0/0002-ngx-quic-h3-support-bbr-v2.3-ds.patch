+/* Kathleen Nichols windowed max filter: maintains best/2nd/3rd estimates
+ * over a fixed window of rounds, with automatic expiry */
+typedef struct {
+    uint64_t  sample;
+    uint64_t  time;
+} ngx_quic_bbr_filter_est_t;
+
+
+typedef struct {
+    uint64_t                 window_length;
+    ngx_quic_bbr_filter_est_t est[3];
+} ngx_quic_bbr_max_filter_t;
