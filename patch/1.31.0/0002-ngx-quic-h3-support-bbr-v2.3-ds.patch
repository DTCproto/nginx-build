@@ -0,0 +1,384 @@
+/*
+ * Copyright (C) Nginx, Inc.
+ */
+
+
+#include <ngx_config.h>
+#include <ngx_core.h>
+#include <ngx_event.h>
+#include <ngx_event_quic_connection.h>
+
+
+#define NGX_QUIC_BRUTAL_SLOTS          5
+#define NGX_QUIC_BRUTAL_MIN_SAMPLES   50
+#define NGX_QUIC_BRUTAL_MIN_ACK_RATE  800
+
+
+typedef struct {
+    ngx_msec_t                        sec;
+    ngx_uint_t                        acked;
+    ngx_uint_t                        lost;
+} ngx_quic_brutal_slot_t;
+
+
+typedef struct {
+    uint64_t                          base_rate;
+    uint64_t                          pacing_rate;
+    ngx_uint_t                        ack_rate;
+    size_t                            cwnd;
+    ngx_quic_brutal_slot_t            slots[NGX_QUIC_BRUTAL_SLOTS];
+} ngx_quic_brutal_t;
+
+
+static ngx_int_t ngx_quic_brutal_init(ngx_connection_t *c);
+static void ngx_quic_brutal_reset_path(ngx_connection_t *c);
+static ngx_uint_t ngx_quic_brutal_can_send(ngx_connection_t *c,
+    size_t bytes_in_flight);
+static ngx_uint_t ngx_quic_brutal_has_pacing_budget(ngx_connection_t *c,
+    ngx_msec_t now);
+static size_t ngx_quic_brutal_pacing_budget(ngx_connection_t *c,
+    ngx_msec_t now);
+static ngx_msec_t ngx_quic_brutal_time_until_send(ngx_connection_t *c,
+    ngx_msec_t now);
+static void ngx_quic_brutal_on_packet_sent(ngx_connection_t *c,
+    ngx_quic_frame_t *f);
+static void ngx_quic_brutal_on_ack_event(ngx_connection_t *c,
+    ngx_quic_sample_t *sample, ngx_msec_t now);
+static void ngx_quic_brutal_on_loss_event(ngx_connection_t *c,
+    ngx_quic_sample_t *sample, ngx_msec_t now);
+static void ngx_quic_brutal_on_congestion_event(ngx_connection_t *c,
+    ngx_quic_sample_t *sample, ngx_msec_t now);
+static size_t ngx_quic_brutal_get_cwnd(ngx_connection_t *c);
+static void ngx_quic_brutal_set_max_datagram_size(ngx_connection_t *c,
+    size_t max_datagram);
+static void ngx_quic_brutal_on_persistent_congestion(ngx_connection_t *c);
+static void ngx_quic_brutal_init_state(ngx_connection_t *c,
+    ngx_quic_brutal_t *br);
+static void ngx_quic_brutal_update_rate(ngx_connection_t *c,
+    ngx_quic_brutal_t *br);
+static void ngx_quic_brutal_update_ack_rate(ngx_connection_t *c,
+    ngx_quic_brutal_t *br, ngx_quic_sample_t *sample, ngx_msec_t now);
+
+
+const ngx_quic_cc_ops_t  ngx_quic_brutal_ops = {
+    ngx_quic_brutal_init,
+    ngx_quic_brutal_reset_path,
+    ngx_quic_brutal_can_send,
+    ngx_quic_brutal_has_pacing_budget,
+    ngx_quic_brutal_pacing_budget,
+    ngx_quic_brutal_time_until_send,
+    ngx_quic_brutal_on_packet_sent,
+    ngx_quic_brutal_on_ack_event,
+    ngx_quic_brutal_on_loss_event,
+    ngx_quic_brutal_on_congestion_event,
+    ngx_quic_brutal_get_cwnd,
+    ngx_quic_brutal_set_max_datagram_size,
+    ngx_quic_brutal_on_persistent_congestion
+};
+
+
+static ngx_int_t
+ngx_quic_brutal_init(ngx_connection_t *c)
+{
+    ngx_quic_brutal_t      *br;
+    ngx_quic_connection_t  *qc;
+
+    qc = ngx_quic_get_connection(c);
+
+    br = ngx_pcalloc(c->pool, sizeof(ngx_quic_brutal_t));
+    if (br == NULL) {
+        return NGX_ERROR;
+    }
+
+    qc->cc.ctx = br;
+    ngx_quic_brutal_init_state(c, br);
+
+    return NGX_OK;
+}
+
+
+static void
+ngx_quic_brutal_reset_path(ngx_connection_t *c)
+{
+    ngx_quic_connection_t  *qc;
+
+    qc = ngx_quic_get_connection(c);
+
+    ngx_quic_brutal_init_state(c, qc->cc.ctx);
+}
+
+
+static ngx_uint_t
+ngx_quic_brutal_can_send(ngx_connection_t *c, size_t bytes_in_flight)
+{
+    ngx_quic_brutal_t      *br;
+    ngx_quic_connection_t  *qc;
+
+    qc = ngx_quic_get_connection(c);
+    br = qc->cc.ctx;
+
+    return bytes_in_flight < br->cwnd;
+}
+
+
+static ngx_uint_t
+ngx_quic_brutal_has_pacing_budget(ngx_connection_t *c, ngx_msec_t now)
+{
+    ngx_quic_brutal_t      *br;
+    ngx_quic_connection_t  *qc;
+
+    qc = ngx_quic_get_connection(c);
+    br = qc->cc.ctx;
+
+    return ngx_quic_pacer_budget(&qc->cc.pacer, br->pacing_rate, now)
+           >= qc->path->mtu;
+}
+
+
+static size_t
+ngx_quic_brutal_pacing_budget(ngx_connection_t *c, ngx_msec_t now)
+{
+    ngx_quic_brutal_t      *br;
+    ngx_quic_connection_t  *qc;
+
+    qc = ngx_quic_get_connection(c);
+    br = qc->cc.ctx;
+
+    return ngx_quic_pacer_budget(&qc->cc.pacer, br->pacing_rate, now);
+}
+
+
+static ngx_msec_t
+ngx_quic_brutal_time_until_send(ngx_connection_t *c, ngx_msec_t now)
+{
+    ngx_quic_brutal_t      *br;
+    ngx_quic_connection_t  *qc;
+
+    qc = ngx_quic_get_connection(c);
+    br = qc->cc.ctx;
+
+    return ngx_quic_pacer_time_until_send(&qc->cc.pacer, br->pacing_rate, now);
+}
+
+
+static void
+ngx_quic_brutal_on_packet_sent(ngx_connection_t *c, ngx_quic_frame_t *f)
+{
+    ngx_quic_brutal_t      *br;
+    ngx_quic_connection_t  *qc;
+
+    qc = ngx_quic_get_connection(c);
+    br = qc->cc.ctx;
+
+    ngx_quic_pacer_sent(&qc->cc.pacer, br->pacing_rate, f->send_time, f->plen);
+}
+
+
+static void
+ngx_quic_brutal_on_ack_event(ngx_connection_t *c, ngx_quic_sample_t *sample,
+    ngx_msec_t now)
+{
+    ngx_quic_brutal_t      *br;
+    ngx_quic_connection_t  *qc;
+
+    qc = ngx_quic_get_connection(c);
+    br = qc->cc.ctx;
+
+    ngx_quic_brutal_update_ack_rate(c, br, sample, now);
+    ngx_quic_brutal_update_rate(c, br);
+}
+
+
+static void
+ngx_quic_brutal_on_loss_event(ngx_connection_t *c, ngx_quic_sample_t *sample,
+    ngx_msec_t now)
+{
+    ngx_quic_brutal_t      *br;
+    ngx_quic_connection_t  *qc;
+
+    qc = ngx_quic_get_connection(c);
+    br = qc->cc.ctx;
+
+    ngx_quic_brutal_update_ack_rate(c, br, sample, now);
+    ngx_quic_brutal_update_rate(c, br);
+}
+
+
+static void
+ngx_quic_brutal_on_congestion_event(ngx_connection_t *c,
+    ngx_quic_sample_t *sample, ngx_msec_t now)
+{
+    ngx_quic_brutal_t      *br;
+    ngx_quic_connection_t  *qc;
+
+    qc = ngx_quic_get_connection(c);
+    br = qc->cc.ctx;
+
+    ngx_quic_brutal_update_ack_rate(c, br, sample, now);
+    ngx_quic_brutal_update_rate(c, br);
+}
+
+
+static size_t
+ngx_quic_brutal_get_cwnd(ngx_connection_t *c)
+{
+    ngx_quic_brutal_t      *br;
+    ngx_quic_connection_t  *qc;
+
+    qc = ngx_quic_get_connection(c);
+    br = qc->cc.ctx;
+
+    return br->cwnd;
+}
+
+
+static void
+ngx_quic_brutal_set_max_datagram_size(ngx_connection_t *c, size_t max_datagram)
+{
+    ngx_quic_brutal_t      *br;
+    ngx_quic_connection_t  *qc;
+
+    qc = ngx_quic_get_connection(c);
+    br = qc->cc.ctx;
+
+    ngx_quic_pacer_set_max_datagram(&qc->cc.pacer, max_datagram);
+    ngx_quic_brutal_update_rate(c, br);
+}
+
+
+static void
+ngx_quic_brutal_on_persistent_congestion(ngx_connection_t *c)
+{
+    ngx_quic_brutal_t      *br;
+    ngx_quic_connection_t  *qc;
+
+    qc = ngx_quic_get_connection(c);
+    br = qc->cc.ctx;
+
+    br->cwnd = ngx_max(4 * qc->path->mtu, NGX_QUIC_MIN_INITIAL_SIZE);
+    qc->congestion.window = br->cwnd;
+}
+
+
+static void
+ngx_quic_brutal_init_state(ngx_connection_t *c, ngx_quic_brutal_t *br)
+{
+    ngx_quic_connection_t  *qc;
+
+    qc = ngx_quic_get_connection(c);
+
+    ngx_memzero(br, sizeof(ngx_quic_brutal_t));
+
+    ngx_quic_cc_reset_default(c);
+
+    br->base_rate = qc->conf->brutal_up;
+    br->ack_rate = 1000;
+
+    ngx_quic_brutal_update_rate(c, br);
+    ngx_quic_pacer_init(&qc->cc.pacer, NGX_QUIC_MIN_INITIAL_SIZE);
+
+    ngx_log_debug3(NGX_LOG_DEBUG_EVENT, c->log, 0,
+                   "quic brutal init up:%uL rate:%uL cwnd:%uz",
+                   br->base_rate, br->pacing_rate, br->cwnd);
+}
+
+
+static void
+ngx_quic_brutal_update_rate(ngx_connection_t *c, ngx_quic_brutal_t *br)
+{
+    uint64_t                cwnd, rtt;
+    ngx_quic_connection_t  *qc;
+
+    qc = ngx_quic_get_connection(c);
+
+    br->pacing_rate = br->base_rate;
+
+    if (qc->conf->brutal_compensate_loss && br->ack_rate != 0) {
+        if (br->base_rate > (uint64_t) -1 / 1000) {
+            br->pacing_rate = (uint64_t) -1 / br->ack_rate;
+
+        } else {
+            br->pacing_rate = br->base_rate * 1000 / br->ack_rate;
+        }
+    }
+
+    rtt = ngx_max(qc->avg_rtt, 1);
+
+    if (br->pacing_rate > (uint64_t) NGX_MAX_SIZE_T_VALUE / rtt) {
+        cwnd = NGX_MAX_SIZE_T_VALUE;
+
+    } else {
+        cwnd = br->pacing_rate * rtt / 1000;
+        cwnd = (cwnd > (uint64_t) NGX_MAX_SIZE_T_VALUE / 2)
+               ? NGX_MAX_SIZE_T_VALUE : cwnd * 2;
+    }
+
+    cwnd = ngx_max(cwnd, 4 * qc->path->mtu);
+    cwnd = ngx_min(cwnd, NGX_MAX_SIZE_T_VALUE);
+
+    br->cwnd = (size_t) cwnd;
+    qc->congestion.window = br->cwnd;
+
+    ngx_log_debug6(NGX_LOG_DEBUG_EVENT, c->log, 0,
+                   "quic brutal rate up:%uL rate:%uL ack:%ui"
+                   " cwnd:%uz rtt:%M if:%uz",
+                   br->base_rate, br->pacing_rate, br->ack_rate, br->cwnd,
+                   qc->avg_rtt, qc->congestion.in_flight);
+}
+
+
+static void
+ngx_quic_brutal_update_ack_rate(ngx_connection_t *c, ngx_quic_brutal_t *br,
+    ngx_quic_sample_t *sample, ngx_msec_t now)
+{
+    ngx_msec_t                sec, min;
+    ngx_uint_t                i, acked, lost, total, slot;
+    ngx_quic_brutal_slot_t   *bs;
+    ngx_quic_connection_t    *qc;
+
+    qc = ngx_quic_get_connection(c);
+
+    if (!qc->conf->brutal_compensate_loss) {
+        br->ack_rate = 1000;
+        return;
+    }
+
+    sec = now / 1000;
+    slot = sec % NGX_QUIC_BRUTAL_SLOTS;
+    bs = &br->slots[slot];
+
+    if (bs->sec != sec) {
+        ngx_memzero(bs, sizeof(ngx_quic_brutal_slot_t));
+        bs->sec = sec;
+    }
+
+    bs->acked += sample->acked_packets;
+    bs->lost += sample->lost_packets;
+
+    acked = 0;
+    lost = 0;
+    min = (sec > NGX_QUIC_BRUTAL_SLOTS) ? sec - NGX_QUIC_BRUTAL_SLOTS : 0;
+
+    for (i = 0; i < NGX_QUIC_BRUTAL_SLOTS; i++) {
+        if (br->slots[i].sec < min) {
+            continue;
+        }
+
+        acked += br->slots[i].acked;
+        lost += br->slots[i].lost;
+    }
+
+    total = acked + lost;
+
+    if (total < NGX_QUIC_BRUTAL_MIN_SAMPLES) {
+        br->ack_rate = 1000;
+        return;
+    }
+
+    br->ack_rate = acked * 1000 / total;
+    br->ack_rate = ngx_max(br->ack_rate, NGX_QUIC_BRUTAL_MIN_ACK_RATE);
+
+    ngx_log_debug4(NGX_LOG_DEBUG_EVENT, c->log, 0,
+                   "quic brutal ack-rate acked:%ui lost:%ui total:%ui rate:%ui",
+                   acked, lost, total, br->ack_rate);
+}
