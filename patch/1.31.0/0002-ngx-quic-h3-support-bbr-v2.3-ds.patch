     cg->in_flight -= f->plen;
@@ -451,6 +549,31 @@ done:
 }
 
 
+static void
+ngx_quic_congestion_ack_event(ngx_connection_t *c, ngx_quic_frame_t *f,
+    ngx_quic_cc_event_t *event)
+{
+    ngx_quic_congestion_t  *cg;
+    ngx_quic_connection_t  *qc;
+
+    if (f->plen == 0) {
+        return;
+    }
+
+    qc = ngx_quic_get_connection(c);
+    cg = &qc->congestion;
+
+    if (f->pnum < qc->rst_pnum) {
+        return;
+    }
+
+    ngx_quic_sampler_on_packet_acked(c, f, &event->sample);
+
+    cg->in_flight = (cg->in_flight > f->plen) ? cg->in_flight - f->plen
+                                              : 0;
+}
+
