+    ngx_quic_cc_event_finalize(c, &cc_event);
+
+    return NGX_OK;
 }
 
 
@@ -251,7 +334,8 @@ ngx_quic_rtt_sample(ngx_connection_t *c, ngx_quic_ack_frame_t *ack,
 
